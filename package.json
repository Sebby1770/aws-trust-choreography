{
  "name": "aws-resilience-command-atlas",
  "version": "1.0.0",
  "description": "Interactive AWS resilience command atlas and architecture studio built with vanilla HTML, CSS, and JavaScript.",
  "type": "module",
  "license": "MIT",
  "author": "Sebastian Forbes (https://github.com/Sebby1770)",
  "homepage": "https://github.com/Sebby1770/aws-trust-choreography#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sebby1770/aws-trust-choreography.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run test",
    "build:icons": "node tools/build-aws-icon-catalog.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
